// A function with a precondition, and a caller that satisfies it.
// `rvc examples/div.rv --run` verifies the obligations and runs main().

fn div(x: i64, y: i64) -> i64
  requires y != 0;
{
  return x / y;
}

fn main() -> i64 {
  let a: i64 = 10;
  let b: i64 = 2;
  assert b != 0;
  return div(a, b);
}
