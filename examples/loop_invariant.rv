// Loop-invariant verification: the invariant `i >= 0` holds on entry and is
// preserved by the body, so it is proved by induction (linear arithmetic).
// `rvc examples/loop_invariant.rv` reports VERIFIED.

fn sum_to(n: i64) -> i64
  requires n >= 0;
{
  let i: i64 = 0;
  let s: i64 = 0;
  while i < n
    invariant i >= 0;
  {
    i = i + 1;
    s = s + i;
  }
  return s;
}
