              False.rec.{0} (fun (_ : False) => And2 (Eq.{1} Ty Cc Afix) (HasTy (Ctx.cons Afix Gv) body Afix))
                (exp_noconf (Exp.ecase s2 l2 r2) (Exp.efix Afix body) (Eq.refl.{1} Bool Bool.false) heq)
