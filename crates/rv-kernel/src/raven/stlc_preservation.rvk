          | HasTy.tbool(Gv, b2) => fun (Alam : Ty) (body : Exp) (heq : Eq.{1} Exp (Exp.ebool b2) (Exp.elam Alam body)) =>
              False.rec.{0} (fun (_ : False) => ExTy (fun (B : Ty) => And2 (Eq.{1} Ty Ty.tbool (Ty.tarrow Alam B)) (HasTy (Ctx.cons Alam Gv) body B)))
