          | HasTy.tadd(Gv, a2, b2, da, db) => fun (f : Exp) (a : Exp) (heq : Eq.{1} Exp (Exp.eadd a2 b2) (Exp.eapp f a)) =>
              False.rec.{0} (fun (_ : False) => ExTy (fun (A : Ty) => And2 (HasTy Gv f (Ty.tarrow A Ty.tnat)) (HasTy Gv a A)))
