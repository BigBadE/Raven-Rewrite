                (exp_ty_proj_inj fixTyOf (Exp.efix A2 body2) (Exp.efix Afix body) heq)
                (Eq.subst.{1} Ctx (fun (g : Ctx) => HasTy g body Afix) (Ctx.cons A2 Gv) (Ctx.cons Afix Gv)
