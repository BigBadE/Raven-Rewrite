              False.rec.{0} (fun (_ : False) => Eq.{1} Bool (isLam(Exp.eif(cnd2, thn2, els2))) Bool.true) (ff_ne_tt h1)
          | HasTy.tfix(G2, A2, body2, dbody) => fun (h1 : Eq.{1} Bool (isValue(Exp.efix(A2, body2))) Bool.true) (h2 : Eq.{1} Bool (isArrow(A2)) Bool.true) =>
