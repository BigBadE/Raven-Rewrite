        | Exp.epair(a, b) => fun (h : Eq.{1} Bool (isLam(Exp.epair(a, b))) Bool.true) =>
            False.rec.{0} (fun (_ : False) => Eq.{1} Exp (Exp.epair a b) (Exp.elam (lamTyOf(Exp.epair(a, b))) (lamBodyOf(Exp.epair(a, b))))) (ff_ne_tt h)
